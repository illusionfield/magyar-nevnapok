{
  "name": "magyar-nevnapok",
  "version": "0.7.0",
  "description": "Magyar hivatalos névnap adatbázis és iCalendar fájl generátor",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./web/server/dev.mjs",
    "start": "node ./web/server/start.mjs",
    "build": "vite build",
    "data:build": "node ./scripts/data-build.mjs",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "node ./scripts/typecheck.mjs",
    "test": "node --test",
    "ellenorzes": "npm run lint && npm run typecheck && npm test && npm run build",
    "audit": "npm audit"
  },
  "author": "illusionfield <illusionfield@gmail.com>",
  "license": "MIT License",
  "dependencies": {
    "ajv": "^8.18.0",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "puppeteer": "^24.42.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "vite": "^8.0.9"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.0.0-rc.16"
  }
}
