{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/unified-primary-report.schema.json",
  "title": "Unified primary registry report",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "inputs",
    "config",
    "stats",
    "summary",
    "days",
    "reviewQueue"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "object",
      "required": ["inputPath", "diffPath"],
      "properties": {
        "inputPath": { "type": "string" },
        "diffPath": { "type": "string" }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object"
    },
    "stats": {
      "type": "object",
      "required": [
        "dayCount",
        "preferredNameCount",
        "oneNameDays",
        "twoNameDays",
        "threeOrMoreNameDays"
      ],
      "properties": {
        "dayCount": { "type": "integer" },
        "preferredNameCount": { "type": "integer" },
        "oneNameDays": { "type": "integer" },
        "twoNameDays": { "type": "integer" },
        "threeOrMoreNameDays": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "totalDays",
        "directFromLegacy",
        "directFromDatabase",
        "manualLeapOverride",
        "manualConflictReview",
        "unresolved"
      ],
      "properties": {
        "totalDays": { "type": "integer" },
        "directFromLegacy": { "type": "integer" },
        "directFromDatabase": { "type": "integer" },
        "manualLeapOverride": { "type": "integer" },
        "manualConflictReview": { "type": "integer" },
        "unresolved": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "month",
          "day",
          "monthDay",
          "names",
          "preferredNames",
          "source",
          "confidence",
          "reason",
          "leapSensitive",
          "databaseCandidates",
          "preferredMismatch"
        ],
        "properties": {
          "month": { "type": ["integer", "null"] },
          "day": { "type": ["integer", "null"] },
          "monthDay": { "type": "string" },
          "names": {
            "type": "array",
            "items": { "type": "string" }
          },
          "preferredNames": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "reason": { "type": "string" },
          "leapSensitive": { "type": "boolean" },
          "databaseCandidates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "canonicalName",
                "currentPrimary",
                "primaryRanked",
                "primaryLegacy",
                "bestScore",
                "rankingScore",
                "overallRank",
                "newbornRank"
              ],
              "properties": {
                "canonicalName": { "type": "string" },
                "currentPrimary": { "type": "boolean" },
                "primaryRanked": { "type": "boolean" },
                "primaryLegacy": { "type": "boolean" },
                "bestScore": { "type": "number" },
                "rankingScore": { "type": "number" },
                "overallRank": { "type": "number" },
                "newbornRank": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "preferredMismatch": {
            "type": ["object", "null"],
            "properties": {
              "type": { "type": "string" },
              "legacy": {
                "type": "array",
                "items": { "type": "string" }
              },
              "wiki": {
                "type": "array",
                "items": { "type": "string" }
              },
              "normalizedLegacy": {
                "type": "array",
                "items": { "type": "string" }
              },
              "normalizedDatabase": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "reviewQueue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "monthDay",
          "reason",
          "legacy",
          "wiki",
          "normalizedLegacy",
          "normalizedWiki",
          "normalizedDatabase",
          "nameIndexSuggestions",
          "relatedSuggestions"
        ],
        "properties": {
          "monthDay": { "type": "string" },
          "reason": { "type": "string" },
          "legacy": {
            "type": "array",
            "items": { "type": "string" }
          },
          "wiki": {
            "type": "array",
            "items": { "type": "string" }
          },
          "normalizedLegacy": {
            "type": "array",
            "items": { "type": "string" }
          },
          "normalizedWiki": {
            "type": "array",
            "items": { "type": "string" }
          },
          "normalizedDatabase": {
            "type": "array",
            "items": { "type": "string" }
          },
          "nameIndexSuggestions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "relatedSuggestions": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
